# ============================================================
# VARIÁVEIS DE AMBIENTE — MS Advocacia
# ============================================================
# Copie este arquivo para .env (nunca commite o .env real)
# cp .env.example .env
# ============================================================

# --- Google Places API ---
# Chave de API do Google Cloud com "Places API" habilitada
# Como obter: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=SUA_CHAVE_AQUI

# Place ID do escritório no Google Meu Negócio
# Como obter: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
# Ou: busque "MS Advocacia" no Google Maps → clique em "Compartilhar" → copie o link → o Place ID está no parâmetro "1s"
VITE_GOOGLE_PLACE_ID=SEU_PLACE_ID_AQUI
